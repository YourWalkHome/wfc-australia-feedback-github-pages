# Required for live AI-powered Compass replies.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4.1-mini if not set.
OPENAI_MODEL=gpt-4.1-mini

# Used by the handover endpoint.
BEN_EMAIL=ben@wfcaust.com.au

# Optional for real email sending through Resend.
# If these are not set, the handover endpoint returns a mailto link instead.
RESEND_API_KEY=
HANDOVER_FROM_EMAIL=

# Alias accepted by the backend if you prefer this simpler name.
FROM_EMAIL=

# Optional protected Compass Mail owner workspace.
# This lets Compass manage only the configured Outlook IMAP mailbox and create
# Outlook drafts for Ben to review/send manually. There is no send endpoint.
COMPASS_MAIL_ADMIN_TOKEN=
COMPASS_MAIL_ADDRESS=ben@wfcaust.com.au
COMPASS_MAIL_USER=ben@wfcaust.com.au
COMPASS_MAIL_PASSWORD=
COMPASS_MAIL_ACCESS_TOKEN=
COMPASS_MAIL_IMAP_HOST=outlook.office365.com
COMPASS_MAIL_IMAP_PORT=993
COMPASS_MAIL_IMAP_SECURE=true
COMPASS_MAIL_DRAFTS_MAILBOX=Drafts
COMPASS_MAIL_ARCHIVE_MAILBOX=Archive
COMPASS_MAIL_TRASH_MAILBOX=Deleted Items
